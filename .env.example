# Supabase
# קבל את הערכים האלה מ-https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — שמור אותו SECRET, אל תחשוף ב-client!
# משמש רק ב-API routes בצד השרת
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# כתובת הבסיס של האפליקציה (ב-Vercel — תהיה ה-domain שלך)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TODO: הוסף כאן לאחר שדרוג ל-auth מלא:
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=
